# Copy to server/.env and adjust for your environment.
# .env is gitignored; .env.example is committed.

# ── Memory ────────────────────────────────────────────────────────────────────
# Production server (16 GB host)
INIT_MEMORY=4G
MAX_MEMORY=16G
SOFT_MAX_HEAP=14G
MEMORY_LIMIT=16g

# ── CPU ───────────────────────────────────────────────────────────────────────
CPU_LIMIT=12

# -- Branch --
BRANCH=https://downloads.wesleys.world/CHANGE_ME/pack.toml
CONFIG_DIR=./config
DEFAULT_CONFIGS_DIR=./defaultconfigs
KUBEJS_DIR=./kubejs